# BYO project + VPC + CryptoKey; we provision only the GKE cluster, secrets, and
# workload identity into the customer's existing network and key. The customer's
# subnet MUST carry secondary ranges named "<name>-pods" / "<name>-services"
# (here "workload-pods" / "workload-services"). The preflight cloud stages for the
# BYO concerns self-gate to amber (not applicable), never red. This is an
# operations reference; runnable split examples live under roots/gcp-full.

project_mode = "byo"
project_id   = "customer-project-id"

region = "us-central1"
name   = "workload"
k8s_version = "1.34"

# BYO network: resolve the customer's VPC + subnet.
network_mode     = "byo"
byo_network_name = "customer-vpc"
byo_subnet_name  = "customer-subnet"

# BYO KMS: resolve the customer's CryptoKey (canonical resource id).
kms_mode      = "byo"
byo_kms_key_id = "projects/customer-project-id/locations/us-central1/keyRings/customer-ring/cryptoKeys/customer-key"

# Provision the cluster + workload identity.
iam_mode     = "provision"
cluster_mode = "provision"

preflight_binary = "/path/to/multicloud-workload-deploy/operator/bin/preflight"
kubeconfig_path  = "/tmp/gcp-full.kubeconfig"

namespace                 = "workload-system"
service_account           = "workload"
operator_image_repository = "ghcr.io/my-org/workload-operator"
operator_image_tag        = "0.1.0"
# operator_image_pull_secret = { server = "ghcr.io", username = "...", password = "...", email = "..." }

control_plane_fqdn   = "satellite.control.ops.dev"
egress_allowed_fqdns = ["ghcr.io", "github.com", "pkg-containers.githubusercontent.com"]
egress_allowed_cidrs = ["185.199.108.0/22"]

observability_enabled        = false
create_secret_provider_class = true

workload_name = "demo"
workload_spec_yaml = <<-YAML
  image: gcr.io/google-samples/hello-app:1.0
  port: 8080
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 512Mi
  securityContext:
    runAsUser: 1000
    runAsNonRoot: true
    allowPrivilegeEscalation: false
    capabilities:
      drop:
        - ALL
    seccompProfile:
      type: RuntimeDefault
  autoscale:
    minReplicas: 2
    maxReplicas: 5
    targetCPUUtilization: 70
YAML

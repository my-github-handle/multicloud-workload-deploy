# Example terraform.tfvars for the aws-full greenfield root — single apply.
# Copy into your aws-full composition root as terraform.tfvars and edit the
# placeholders. Do NOT commit real credentials or account IDs.

region      = "us-east-1"
name        = "workload"
azs         = ["us-east-1a", "us-east-1b"]
k8s_version = "1.34"

# Primary CIDR = edge (public + firewall subnets); secondary = data plane
# (node + pod subnets) on the CGNAT block so pod IP churn never exhausts routable space.
vpc_primary_cidr   = "10.0.0.0/24"
vpc_secondary_cidr = "100.64.0.0/16"

# All provision by default; flip any to "byo" + supply the byo_* value.
network_mode = "provision"
kms_mode     = "provision"
iam_mode     = "provision"
cluster_mode = "provision"

# Absolute path to the preflight binary (mage preflightBuild).
preflight_binary = "/path/to/multicloud-workload-deploy/operator/bin/preflight"
# Rendered during the apply from the cluster-resolver outputs; just a writable path.
kubeconfig_path = "/tmp/aws-full.kubeconfig"

namespace                 = "workload-system"
service_account           = "workload"
operator_image_repository = "ghcr.io/my-org/workload-operator"
operator_image_tag        = "0.1.0"
psa_enforce_level         = "restricted"

# The operator image is private — supply pull credentials so the root creates a
# docker-registry secret and wires it onto the operator ServiceAccount.
# operator_image_pull_secret = {
#   server   = "ghcr.io"
#   username = "my-org-bot"
#   password = "ghp_xxx_read_packages_token"
#   email    = "ci@example.com"
# }

control_plane_fqdn   = "satellite.control.ops.dev"
control_plane_port   = 443
egress_allowed_fqdns = ["ghcr.io", "github.com", "pkg-containers.githubusercontent.com"]

# Optional in-cluster identity-aware layer (NetworkPolicy / Hubble / toFQDNs) on
# top of the VPC CNI. Off by default; the perimeter firewall + Layer-3 floor suffice.
install_cilium        = false
observability_enabled = false

# The SecretProviderClass renders in the same apply (the Secrets Store CSI add-on
# provides the CRD).
create_secret_provider_class = true

secrets = {
  # "db-password" = "change-me-then-rotate-out-of-band"
}

workload_name = "demo"
# The spec is the WorkloadSpec verbatim (no `name` — that comes from workload_name).
# Container securityContext must satisfy the namespace's restricted Pod Security
# Admission, and the image must run as non-root.
workload_spec_yaml = <<-YAML
  image: gcr.io/google-samples/hello-app:1.0
  port: 8080
  securityContext:
    runAsUser: 1000
    runAsNonRoot: true
    allowPrivilegeEscalation: false
    capabilities:
      drop:
        - ALL
    seccompProfile:
      type: RuntimeDefault
  autoscale:
    minReplicas: 2
    maxReplicas: 5
    targetCPUUtilization: 70
  livenessProbe:
    path: /
    port: 8080
  readinessProbe:
    path: /
    port: 8080
YAML

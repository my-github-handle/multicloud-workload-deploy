# Example terraform.tfvars for the azure-full greenfield root — single apply.
# Copy into your azure-full composition root as terraform.tfvars and edit the
# placeholders. Do NOT commit real credentials or IDs.

subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "11111111-1111-1111-1111-111111111111"
location        = "eastus"
name            = "workload"

# Single VNet CIDR — nodes only; pods use the CNI overlay (pod_cidr), so this can
# stay small. Pods default to 100.64.0.0/16, services to 172.20.0.0/16.
address_space = ["10.0.0.0/16"]
k8s_version   = "1.34"

# All provision by default; flip any to "byo" + supply the byo_* value.
network_mode = "provision"
kms_mode     = "provision"
iam_mode     = "provision"
cluster_mode = "provision"

# Absolute path to the preflight binary (mage preflightBuild).
preflight_binary = "/path/to/multicloud-workload-deploy/operator/bin/preflight"
# Greenfield generates the kubeconfig in-graph and ignores kubeconfig_path; set
# it only for cluster_mode = "byo".

namespace                 = "workload-system"
service_account           = "workload"
operator_image_repository = "ghcr.io/my-org/workload-operator"
operator_image_tag        = "0.1.0"

# The operator image is private — supply pull credentials so the root creates a
# docker-registry secret and wires it onto the operator ServiceAccount. Pass at
# apply (never commit): -var 'operator_image_pull_secret={...}'.
# operator_image_pull_secret = {
#   server   = "ghcr.io"
#   username = "my-org-bot"
#   password = "ghp_xxx_read_packages_token"
#   email    = "ci@example.com"
# }

control_plane_fqdn = "satellite.control.ops.dev"
control_plane_port = 443
# ghcr.io serves image blobs from pkg-containers.githubusercontent.com — include
# it or private/public ghcr pulls fail at the blob fetch (manifest OK, blob EOF).
egress_allowed_fqdns = ["ghcr.io", "github.com", "pkg-containers.githubusercontent.com", "*.azurecr.io", "login.microsoftonline.com"]

# In-cluster ServiceMonitor needs the Prometheus operator CRDs; enable only if present.
observability_enabled = false

secrets = {
  # "db-password" = "change-me-then-rotate-out-of-band"
}

workload_name = "demo"
workload_port = 80
# WorkloadSpec verbatim (no `name` — that comes from workload_name). The container
# securityContext must satisfy the namespace's restricted Pod Security Admission
# (runAsNonRoot + numeric runAsUser, allowPrivilegeEscalation=false, drop ALL
# caps, RuntimeDefault seccomp) and the image must run as non-root.
workload_spec_yaml = <<-YAML
  image: nginx:1.27
  port: 80
  autoscale:
    minReplicas: 2
    maxReplicas: 5
    targetCPUUtilization: 70
  livenessProbe:
    path: /
    port: 80
  readinessProbe:
    path: /
    port: 80
YAML

# Testing only: expose the API server publicly to a single IP (nodes egress via
# the firewall IP, which the root adds automatically). NEVER commit the IP — pass
# at apply: -var 'cluster_private=false' \
#   -var 'cluster_authorized_ip_ranges=["203.0.113.4/32"]' \
#   -var 'kms_allowed_ip_ranges=["203.0.113.4/32"]'
# cluster_private = true

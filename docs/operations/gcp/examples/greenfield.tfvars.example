# Example values for the gcp-full greenfield roots.
# The shipped runnable examples live under roots/gcp-full/phase1-infra and
# roots/gcp-full/phase2-deploy. Keep this as an operations reference only.

# --- project container (created by Terraform; or set project_mode="byo") ---
project_mode    = "provision"
project_id      = "my-gcp-project"
project_name    = "Workload Platform"
billing_account = "00X0X0-0X0X0X-0X0X0X"
# org_id    = "123456789012"   # OR folder_id (mutually exclusive)
# folder_id = "987654321098"

region = "us-central1"
name   = "workload"
# Data-plane CIDRs on the CGNAT block (nodes/pods/services); pods on the largest.
subnet_cidr   = "100.64.0.0/18"
pods_cidr     = "100.64.128.0/17"
services_cidr = "100.64.64.0/19"
k8s_version   = "1.34"

# All provision by default; flip any to "byo" + supply the byo_* value.
network_mode = "provision"
kms_mode     = "provision"
iam_mode     = "provision"
cluster_mode = "provision"

# Absolute path to the preflight binary (mage preflightBuild).
preflight_binary = "/path/to/multicloud-workload-deploy/operator/bin/preflight"
# Rendered during the apply from the cluster-resolver outputs; just a writable path.
kubeconfig_path = "/tmp/gcp-full.kubeconfig"

namespace                 = "workload-system"
service_account           = "workload"
operator_image_repository = "ghcr.io/my-org/workload-operator"
operator_image_tag        = "0.1.0"
# The sre-interview image runs as root with a writable rootfs, so "restricted"
# (which forbids root) would reject it. "baseline" still blocks privileged /
# hostNamespace / hostPath. Use "restricted" for non-root images.
psa_enforce_level = "baseline"

# The operator image is private — supply pull credentials so the root creates a
# docker-registry secret and wires it onto the operator ServiceAccount.
# operator_image_pull_secret = {
#   server   = "ghcr.io"
#   username = "my-org-bot"
#   password = "ghp_xxx_read_packages_token"
#   email    = "ci@example.com"
# }

control_plane_fqdn   = "satellite.control.ops.dev"
control_plane_port   = 443
egress_allowed_fqdns = ["ghcr.io", "github.com", "pkg-containers.githubusercontent.com"]
# Cloud NGFW cannot wildcard-match the ghcr blob CDN (served from many
# githubusercontent.com hosts), so allow its published IP range by CIDR.
egress_allowed_cidrs = ["185.199.108.0/22"]

# In-cluster ServiceMonitor needs the Prometheus operator CRDs; enable only if present.
observability_enabled = false

# The SecretProviderClass renders in phase 2 (the GKE Secret Manager CSI add-on
# is enabled by the phase-1 cluster).
create_secret_provider_class = true

secrets = {
  # "db-password" = "change-me-then-rotate-out-of-band"
}

# The sre-interview workload: HTTP app on :8080, internal/metrics on :9090.
workload_name = "demo"
# WorkloadSpec verbatim (no `name` — that comes from workload_name). This image
# runs as root with a writable rootfs, so the hardened chart defaults (runAsNonRoot
# + readOnlyRootFilesystem) are overridden; drop ALL caps + RuntimeDefault seccomp
# are kept. The operator wires the Service to :8080.
workload_spec_yaml = <<-YAML
  image: ghcr.io/e2b-dev/sre-interview:latest
  port: 8080
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 512Mi
  securityContext:
    runAsNonRoot: false
    allowPrivilegeEscalation: false
    readOnlyRootFilesystem: false
    capabilities:
      drop:
        - ALL
    seccompProfile:
      type: RuntimeDefault
  autoscale:
    minReplicas: 2
    maxReplicas: 5
    targetCPUUtilization: 70
  livenessProbe:
    path: /
    port: 8080
  readinessProbe:
    path: /
    port: 8080
YAML

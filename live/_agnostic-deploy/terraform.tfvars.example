# Copy to terraform.tfvars and fill in. BYOC fast path — kubeconfig only.
kubeconfig_path  = "/home/se/.kube/customer-cluster.yaml"
kube_context     = "" # empty = current-context
preflight_binary = "/home/se/multicloud-workload-deploy/operator/bin/preflight"

namespace = "workload-system"

# Operator image. Override tag per release.
operator_image_repository = "ghcr.io/ops-dev/workload-operator"
operator_image_tag        = "0.1.0"

# Control-plane egress PORT (the in-cluster egress-allow opens this port on a wide CIDR minus the
# metadata IPs). FQDN scoping is the perimeter firewall's job, not this in-cluster floor — so there
# is no control_plane_fqdn here.
control_plane_port = 443

# Disable if the customer cluster has no Prometheus-operator (ServiceMonitor CRD).
observability_enabled = true

# Workload. The spec is one YAML document (the single source for both install tiers); its fields
# match the Workload CRD spec and charts/workload values.schema.json. Use file("workload.yaml") to
# keep it in its own file, or an inline heredoc as shown. The security-context overrides below are
# only needed for an image that cannot run under the hardened default (non-root, read-only root fs,
# drop ALL) — e.g. stock nginx, which needs root and a writable filesystem.
workload_name = "demo"
workload_spec_yaml = <<-YAML
  image: nginx:1.27
  port: 80
  autoscale:
    minReplicas: 2
    maxReplicas: 10
    targetCPUUtilization: 70
  livenessProbe:
    path: /
    port: 80
  readinessProbe:
    path: /
    port: 80
  # nginx runs as root and writes to its filesystem — relax the hardened default just enough:
  podSecurityContext:
    runAsNonRoot: false
    seccompProfile:
      type: RuntimeDefault
  securityContext:
    readOnlyRootFilesystem: false
    allowPrivilegeEscalation: false
    capabilities:
      drop: ["ALL"]
YAML

# Leave empty to derive the tier from preflight; set "A" or "B" to force it.
install_tier_override = ""

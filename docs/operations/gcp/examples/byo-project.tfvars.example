# BYO project, greenfield everything else. The customer pre-created the GCP
# project (the common BYOC case); we resolve it (and ensure the required service
# APIs are enabled), then provision network + KMS + GKE + secrets + identity into
# it. This is an operations reference; runnable split examples live under
# roots/gcp-full/{phase1-infra,phase2-deploy}.

# --- project: resolve an existing one (do NOT create) ---
project_mode = "byo"
project_id   = "customer-project-id"
# billing_account / folder_id / org_id are not needed in byo mode.

region = "us-central1"
name   = "workload"
subnet_cidr   = "100.64.0.0/18"
pods_cidr     = "100.64.128.0/17"
services_cidr = "100.64.64.0/19"
k8s_version   = "1.34"

# Everything else greenfield.
network_mode = "provision"
kms_mode     = "provision"
iam_mode     = "provision"
cluster_mode = "provision"

preflight_binary = "/path/to/multicloud-workload-deploy/operator/bin/preflight"
kubeconfig_path  = "/tmp/gcp-full.kubeconfig"

namespace                 = "workload-system"
service_account           = "workload"
operator_image_repository = "ghcr.io/my-org/workload-operator"
operator_image_tag        = "0.1.0"
# operator_image_pull_secret = { server = "ghcr.io", username = "...", password = "...", email = "..." }

control_plane_fqdn   = "satellite.control.ops.dev"
egress_allowed_fqdns = ["ghcr.io", "github.com", "pkg-containers.githubusercontent.com"]
egress_allowed_cidrs = ["185.199.108.0/22"]

observability_enabled        = false
create_secret_provider_class = true

workload_name = "demo"
workload_spec_yaml = <<-YAML
  image: gcr.io/google-samples/hello-app:1.0
  port: 8080
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 512Mi
  securityContext:
    runAsUser: 1000
    runAsNonRoot: true
    allowPrivilegeEscalation: false
    capabilities:
      drop:
        - ALL
    seccompProfile:
      type: RuntimeDefault
  autoscale:
    minReplicas: 2
    maxReplicas: 5
    targetCPUUtilization: 70
YAML
